{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/auth/layout,_N_T_/auth/dashboard/layout,_N_T_/auth/dashboard/page,_N_T_/auth/dashboard"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/auth/dashboard/__PAGE__",
    "/auth/dashboard",
    "/auth",
    "/_index",
    "/_head"
  ]
}