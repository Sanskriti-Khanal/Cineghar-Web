{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/auth/layout,_N_T_/auth/movies/layout,_N_T_/auth/movies/page,_N_T_/auth/movies"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/auth/movies/__PAGE__",
    "/auth/movies",
    "/auth",
    "/_index",
    "/_head"
  ]
}