{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/auth/layout,_N_T_/auth/sales/layout,_N_T_/auth/sales/page,_N_T_/auth/sales"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/auth/sales/__PAGE__",
    "/auth/sales",
    "/auth",
    "/_index",
    "/_head"
  ]
}